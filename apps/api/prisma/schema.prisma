model ImpositionPreset {
  id             String           @id @default(cuid())
  name           String
  bindingType    String
  sheetWidth     Decimal          @db.Decimal(6, 2)
  sheetHeight    Decimal          @db.Decimal(6, 2)
  marginTop      Decimal          @default(5) @db.Decimal(5, 2)
  marginRight    Decimal          @default(5) @db.Decimal(5, 2)
  marginBottom   Decimal          @default(5) @db.Decimal(5, 2)
  marginLeft     Decimal          @default(5) @db.Decimal(5, 2)
  creaseWidth    Decimal?         @db.Decimal(4, 2)
  tackMargin     Decimal?         @db.Decimal(4, 2)
  tackEdge       String?
  gutter         Decimal          @default(3) @db.Decimal(4, 2)
  bleed          Decimal          @default(3) @db.Decimal(4, 2)
  grainDirection String           @default("short")
  rotationPolicy String           @default("auto")
  isDefault      Boolean          @default(false)
  companyId      String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  /// 'A4'|'A5'|'A6'|'B5'|'210x297' 등 (매칭용 메타)
  productSize    String?
  /// 시트당 Nup 고정값 (1/2/4/6/8…). null 이면 자동 계산. compressed 에선 "페어 개수"
  targetNup      Int?
  jobs           ImpositionJob[]
  rules          ImpositionRule[]

  @@index([bindingType])
  @@index([isDefault])
  @@index([productSize, bindingType])
  @@map("imposition_presets")
}

/// 주문 특성(규격·제본방식·페이지수)을 프리셋과 자동 매칭하는 규칙.
/// priority 내림차순 + 조건 매칭 첫 히트가 선택됨.
model ImpositionRule {
  id          String           @id @default(cuid())
  /// 매칭 조건: 제품 규격 라벨. 'A4'|'A5'|'A6'|'B5'|'210x297' 등. null=any
  productSize String?
  /// 매칭 조건: 제본방식. 'compressed'|'tack'|'perfect'|'flat'. null=any
  bindingType String?
  /// 매칭 조건: 페이지 수 범위 (포함). null=무제한
  minPages    Int?
  maxPages    Int?
  /// 큰 값 우선
  priority    Int              @default(0)
  presetId    String
  description String?
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  preset      ImpositionPreset @relation(fields: [presetId], references: [id], onDelete: Cascade)

  @@index([priority])
  @@index([productSize, bindingType])
  @@index([presetId])
  @@map("imposition_rules")
}

model ImpositionJob {
  id           String           @id @default(cuid())
  orderId      String?
  orderItemId  String?
  presetId     String
  pageCount    Int
  sheetCount   Int
  nup          Int
  rotation     Int
  utilization  Decimal          @db.Decimal(5, 4)
  layoutJson   Json
  jdfPath      String?
  pdfPath      String?
  status       String           @default("pending")
  error        String?
  createdAt    DateTime         @default(now())
  imagePdfPath String?
  preset       ImpositionPreset @relation(fields: [presetId], references: [id])

  @@index([orderId])
  @@index([orderItemId])
  @@index([status])
  @@map("imposition_jobs")
}

