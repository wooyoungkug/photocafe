// ====================================================================
// 매입처 견적관리 (거래처에서 받은 견적서 등록/보관)
// /cs/purchase-quotations
// ====================================================================
model PurchaseQuotation {
  id         String   @id @default(cuid())
  vendorName String // 매입처명 (필수)
  receivedAt DateTime // 받은날짜 (필수)
  manager    String? // 담당자
  department String? // 관련부서
  title      String? // 제목/내용
  note       String? // 메모
  files      Json     @default("[]") // [{name, url, type, size}] 배열
  staffId    String? // 등록한 직원
  staff      Staff?   @relation(fields: [staffId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([vendorName])
  @@index([receivedAt])
  @@index([staffId])
  @@map("purchase_quotations")
}

model PrintRoomPreset {
  id                  String         @id @default(cuid())
  sizeCode            String
  nup                 String
  paperOrientation    String
  gridCols            Int
  gridRows            Int
  marginMm            Float          @default(10.0)
  cropMarkLengthMm    Float          @default(5.0)
  cropMarkThicknessPt Float          @default(0.25)
  cropMarkColor       String         @default("K100")
  pdfVersion          String         @default("1.4")
  isActive            Boolean        @default(true)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  jobs                PrintRoomJob[]

  @@unique([sizeCode, nup])
  @@map("print_room_presets")
}

model PrintRoomJob {
  id              String           @id @default(cuid())
  orderItemId     String
  orderItem       OrderItem        @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  presetId        String?
  preset          PrintRoomPreset? @relation(fields: [presetId], references: [id])
  isManual        Boolean          @default(false)
  status          String           @default("pending")
  pdfB2Key        String?
  pageCount       Int?
  sourceFileCount Int?
  processedAt     DateTime?
  errorLog        String?
  staffId         String?
  createdAt       DateTime         @default(now())

  @@index([orderItemId])
  @@index([status])
  @@map("print_room_jobs")
}

model PrintReadyFile {
  id          String             @id @default(cuid())
  orderItemId String
  orderItem   OrderItem          @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  b2Key       String
  fileName    String
  fileSize    Int
  printMethod String
  fileType    String
  preparedAt  DateTime           @default(now())
  downloads   PrintDownloadLog[]

  @@index([orderItemId])
  @@map("print_ready_files")
}

model PrintDownloadLog {
  id               String          @id @default(cuid())
  orderItemId      String
  orderItem        OrderItem       @relation(fields: [orderItemId], references: [id])
  printReadyFileId String?
  printReadyFile   PrintReadyFile? @relation(fields: [printReadyFileId], references: [id])
  staffId          String?
  agentId          String?
  downloadType     String
  fileCount        Int
  totalBytes       BigInt
  localPath        String?
  downloadedAt     DateTime        @default(now())

  @@index([orderItemId])
  @@index([downloadedAt])
  @@index([agentId])
  @@map("print_download_logs")
}

// 데스크톱 핫폴더 에이전트 등록 토큰 (Phase 8).
// - 평문 토큰은 발급 시 1회만 표시되고 DB 에는 SHA-256 해시만 저장됨.
// - tokenPrefix 는 UI 식별용 (예: "ag_a1b2…").
// - 에이전트는 X-Agent-Token 헤더로 호출. hash 검증 후 lastHeartbeatAt 갱신.
model AgentToken {
  id               String    @id @default(cuid())
  name             String    // 식별용 이름 (예: "인쇄PC-1", "잉크젯PC")
  tokenHash        String    @unique // SHA-256 hex
  tokenPrefix      String    // 평문 앞 12자 (UI 표시용)
  machineName      String?   // 에이전트 자가보고 hostname
  lastHeartbeatAt  DateTime?
  lastIp           String?
  isActive         Boolean   @default(true)
  createdByStaffId String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([isActive])
  @@map("agent_tokens")
}
