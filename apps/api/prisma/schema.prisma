  staff              staff?               @relation(fields: [staffId], references: [id])
  sales_receipts     sales_receipts[]

  @@index([clientId])
  @@index([clientId, ledgerDate])
  @@index([dueDate])
  @@index([ledgerDate])
  @@index([orderId])
  @@index([paymentStatus])
  @@index([paymentStatus, ledgerDate])
  @@index([salesStatus])
  @@index([salesStatus, ledgerDate])
  @@index([staffId])
  @@index([staffId, ledgerDate])
}

model sales_receipts {
