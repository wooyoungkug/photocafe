generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  name         String
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  lastLoginAt  DateTime?
  memberType   MemberType   @default(INDIVIDUAL)
  oauthId      String?
  passwordHash String?
  phone        String?
  profileImage String?
  provider     AuthProvider @default(EMAIL)
  client       Client?

  @@unique([provider, oauthId])
  @@index([email])
  @@map("users")
}

model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  category  String
  label     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@map("system_settings")
}

model DeliveryPricing {
  id                   String   @id @default(cuid())
  deliveryMethod       String   @unique
  name                 String
  baseFee              Decimal  @default(0) @db.Decimal(10, 2)
  distanceRanges       Json?
  extraPricePerKm      Decimal? @db.Decimal(10, 2)
  maxBaseDistance      Int?
  nightSurchargeRate   Decimal? @db.Decimal(5, 2)
  nightStartHour       Int?     @default(22)
  nightEndHour         Int?     @default(6)
  weekendSurchargeRate Decimal? @db.Decimal(5, 2)
  sizeRanges           Json?
  islandFee            Decimal? @db.Decimal(10, 2)
  freeThreshold        Decimal? @db.Decimal(10, 2)
  sortOrder            Int      @default(0)
  isActive             Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  packagingFee         Decimal? @db.Decimal(10, 2)
  shippingFee          Decimal? @db.Decimal(10, 2)

  @@map("delivery_pricings")
}

model Department {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  staff       Staff[]
  teams       Team[]

  @@map("departments")
}

model Team {
  id           String     @id @default(cuid())
  code         String     @unique
  name         String
  departmentId String
  leaderId     String?
  description  String?
  sortOrder    Int        @default(0)
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  staff        Staff[]    @relation("TeamMembers")
  department   Department @relation(fields: [departmentId], references: [id])
  leader       Staff?     @relation("TeamLeader", fields: [leaderId], references: [id])

  @@index([departmentId])
  @@map("teams")
}

model AuditLog {
  id            String   @id @default(cuid())
  entityType    String
  entityId      String
  action        String
  changes       Json?
  performedBy   String
  performerName String
  ipAddress     String?
  userAgent     String?
  metadata      Json?
  createdAt     DateTime @default(now())

  @@index([entityType, entityId])
  @@index([performedBy])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

/// 보안 이벤트 로그 (설계서 v1.1)
/// 로그인 성공/실패, 권한 오류, 의심 패턴, 2FA 시도, IP 차단 등 보안 관련 이벤트 기록.
/// AuditLog(비즈니스 변경 이력) 와 분리: SecurityLog 는 침해 분석 / SIEM 연동 전용.
model SecurityLog {
  id        String   @id @default(cuid())
  /// 이벤트 종류: login_success, login_failed, login_blocked,
  ///              password_reset, password_changed,
  ///              2fa_enabled, 2fa_disabled, 2fa_failed,
  ///              token_refresh, token_revoked,
  ///              permission_denied, suspicious_activity,
  ///              ip_blocked, rate_limited
  eventType String
  /// info | warn | critical — SIEM 알림 우선순위
  severity  String   @default("info")
  /// 영향 받은 사용자 (없으면 null — 비인증 사용자 시도)
  userId    String?
  userType  String? // staff | client | employee | unknown
  loginId   String? // 로그인 시도 ID (실패 추적용)
  ipAddress String?
  userAgent String?
  country   String? // GeoIP 분석 결과
  /// 추가 컨텍스트 (실패 사유, 차단 룰 ID 등)
  metadata  Json?
  /// 실패 시 관련 메시지 (개인정보 미포함)
  message   String?
  createdAt DateTime @default(now())

  @@index([eventType])
  @@index([userId])
  @@index([ipAddress])
  @@index([severity])
  @@index([createdAt])
  @@map("security_logs")
}

/// 업로드 속도 메트릭 — 클라이언트→API 및 API→B2 구간 측정값 저장
/// 실 업로드는 10% 샘플링, 속도테스트는 100% 기록.
model UploadMetric {
  id           String   @id @default(cuid())
  /// "real" (실 업로드 샘플) | "speedtest" (관리자 수동 테스트)
  kind         String
  /// "client_to_api" | "api_to_b2" | "b2_download"
  phase        String
  /// 엔드포인트 경로 (/upload/album-file 등)
  endpoint     String?
  userId       String?
  /// staff | client | branch | anonymous
  userType     String?
  /// 바이트 단위 파일 크기
  fileSize     BigInt
  /// 소요시간(밀리초)
  durationMs   Int
  /// 계산값 — KB/s (fileSize / 1024 / (durationMs / 1000))
  speedKbps    Float
  success      Boolean  @default(true)
  errorMessage String?
  clientIp     String?
  userAgent    String?  @db.Text
  /// Cloudflare CF-IPCountry 헤더
  countryCode  String?
  /// 추가 컨텍스트 (CF-Ray, 페어ID 등)
  metadata     Json?
  createdAt    DateTime @default(now())

  @@index([kind, phase, createdAt])
  @@index([endpoint, createdAt])
  @@index([createdAt])
  @@map("upload_metrics")
}

model Staff {
  id                      String                  @id @default(cuid())
  staffId                 String?                 @unique
  password                String?
  name                    String
  branchId                String?
  departmentId            String?
  position                String?
  phone                   String?
  mobile                  String?
  email                   String?
  postalCode              String?
  address                 String?
  addressDetail           String?
  settlementGrade         Int                     @default(1)
  allowedIps              String[]                @default([])
  canEditInManagerView    Boolean                 @default(false)
  canLoginAsManager       Boolean                 @default(false)
  canChangeDepositStage   Boolean                 @default(false)
  canChangeReceptionStage Boolean                 @default(false)
  canChangeCancelStage    Boolean                 @default(false)
  canEditMemberInfo       Boolean                 @default(false)
  canViewSettlement       Boolean                 @default(false)
  canChangeOrderAmount    Boolean                 @default(false)
  memberViewScope         String                  @default("own")
  salesViewScope          String                  @default("own")
  menuPermissions         Json?
  categoryPermissions     Json?
  processPermissions      Json?
  isActive                Boolean                 @default(true)
  lastLoginAt             DateTime?
  lastLoginIp             String?
  adminMemo               String?
  joinDate                DateTime                @default(now())
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt
  isCompany               Boolean                 @default(false)
  isDepartment            Boolean                 @default(true)
  isPersonal              Boolean                 @default(false)
  isSuperAdmin            Boolean                 @default(false)
  approvedAt              DateTime?
  approvedBy              String?
  companyEmail            String?
  oauthId                 String?
  oauthProvider           String?
  profileImage            String?
  role                    String                  @default("employee")
  status                  String                  @default("active")
  canBulkImportStaff      Boolean                 @default(false)
  canManageDepartments    Boolean                 @default(false)
  canViewAuditLogs        Boolean                 @default(false)
  teamId                  String?
  isPhotographer          Boolean                 @default(false)
  photographerGrade       String?
  specialties             String[]                @default([])
  layoutMode              String                  @default("top")
  pinnedMenus             String[]                @default([])
  // 2FA (TOTP) — 설계서 v1.1 보안 요구사항 (관리자 2단계 인증)
  // totpSecret 는 암호화 저장(별도 PII 키 적용) 또는 향후 KMS 연동 예정.
  twoFactorEnabled        Boolean                 @default(false)
  twoFactorSecret         String? // base32 인코딩된 TOTP 시크릿 (암호화 저장)
  twoFactorBackupCodes    String[]                @default([]) // 1회용 백업코드 (해시 저장)
  twoFactorEnabledAt      DateTime?
  assignedClientsAsStaff  Client[]                @relation("ClientAssignedStaff")
  agendaVotes             HrAgendaVote[]          @relation("AgendaVoter")
  targetAgendas           HrAgenda[]              @relation("AgendaTarget")
  committeeMembers        HrCommitteeMember[]
  leaveApprovals          LeaveApproval[]         @relation("LeaveApprover")
  leaveBalances           LeaveBalance[]
  leaveRequests           LeaveRequest[]
  locationLogs            LocationLog[]
  notifications           Notification[]          @relation("StaffNotifications")
  editedOrders            OrderEditHistory[]      @relation("OrderEditor")
  operatedOrders          Order[]                 @relation("OrderPrintOperator")
  photographerStats       PhotographerStats?
  quotations              Quotation[]
  processedReprints       ReprintJob[]            @relation("ReprintProcessor")
  requestedReprints       ReprintJob[]            @relation("ReprintRequester")
  salesLedgers            SalesLedger[]           @relation("SalesLedgerStaff")
  shootingBids            ShootingBid[]
  shootingReviews         ShootingReview[]
  assignedShootings       ShootingSchedule[]      @relation("AssignedPhotographer")
  branch                  Branch?                 @relation(fields: [branchId], references: [id])
  department              Department?             @relation(fields: [departmentId], references: [id])
  team                    Team?                   @relation("TeamMembers", fields: [teamId], references: [id])
  assignedClients         StaffClient[]
  disciplineRecords       StaffDisciplineRecord[]
  pushSubscriptions       StaffPushSubscription[]
  ledTeams                Team[]                  @relation("TeamLeader")
  purchaseQuotations      PurchaseQuotation[]

  @@unique([oauthProvider, oauthId])
  @@index([branchId])
  @@index([departmentId])
  @@index([teamId])
  @@index([isActive])
  @@index([status])
  @@index([oauthProvider])
  @@map("staff")
}

model Company {
  id        String   @id @default(cuid())
  name      String
  domain    String   @unique
  logoUrl   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("companies")
}

model StaffClient {
  id        String   @id @default(cuid())
  staffId   String
  clientId  String
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  staff     Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, clientId])
  @@index([staffId])
  @@index([clientId])
  @@map("staff_clients")
}

model PermissionTemplate {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  permissions Json
  isDefault   Boolean  @default(false)
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("permission_templates")
}

model Branch {
  id             String        @id @default(cuid())
  branchCode     String        @unique
  branchName     String
