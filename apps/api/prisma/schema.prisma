/// 주문 편집 이력 — 누가 / 언제 / 무엇을 / 왜 변경했는지 추적.
/// 사양·금액·페이지·담당자 변경 모두 기록. ReprintJob 발생 시 1:1 연결.
model OrderEditHistory {
  id             String      @id @default(cuid())
  orderId        String
  editorId       String
  editorName     String
  /// [{ field: 'printSide', before: 'single', after: 'double', itemId: '...' }, ...]
  changedFields  Json
  /// [{ itemId, pageNumbers: [3,7] }] — 변경된 페이지 번호 (재출력 사유 추적용)
  changedPages   Json?
  message        String?
  notifyOperator Boolean     @default(false)
  reprintJobId   String?     @unique
  createdAt      DateTime    @default(now())
  editor         Staff       @relation("OrderEditor", fields: [editorId], references: [id])
  order          Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  reprintJob     ReprintJob? @relation(fields: [reprintJobId], references: [id])

  @@index([orderId, createdAt])
  @@index([editorId])
  @@map("order_edit_histories")
}

/// 출력완료 후 사양 변경에 따른 재출력 작업 단위.
/// 페이지 단위 부분 재출력 (변경 페이지만). 추가비용은 Client.pendingAdjustmentAmount에 누적.
model ReprintJob {
  id                String            @id @default(cuid())
  orderId           String
  parentOrderItemId String
  reprintNumber     Int               @default(1)
  /// [{ pageNumber, fileUrl, thumbnailUrl, reason }]
  reprintPages      Json
  reason            String
  additionalCost    Decimal           @default(0) @db.Decimal(10, 2)
  status            String            @default("requested")
  requestedById     String
  processedById     String?
  processedAt       DateTime?
  completedAt       DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  editHistory       OrderEditHistory?
  order             Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  parentItem        OrderItem         @relation("ReprintParent", fields: [parentOrderItemId], references: [id])
  processor         Staff?            @relation("ReprintProcessor", fields: [processedById], references: [id])
  requester         Staff             @relation("ReprintRequester", fields: [requestedById], references: [id])

  @@index([orderId])
  @@index([status])
  @@index([orderId, reprintNumber])
  @@map("reprint_jobs")
}

/// 직원 인앱/카카오 알림. 폴링 30s 또는 카카오 알림톡(Phase 2) 발송.
model Notification {
  id               String    @id @default(cuid())
  recipientStaffId String
  /// order_edit | reprint_request | print_operator_assigned | order_status_changed
  type             String
  title            String
  body             String
  /// { orderId, orderNumber, reprintJobId, ... }
  payload          Json?
  link             String?
  readAt           DateTime?
  /// inapp | kakao
  channel          String    @default("inapp")
  kakaoSentAt      DateTime?
  /// sent | failed | skipped
  kakaoStatus      String?
  createdAt        DateTime  @default(now())
  recipient        Staff     @relation("StaffNotifications", fields: [recipientStaffId], references: [id], onDelete: Cascade)

  @@index([recipientStaffId, readAt])
  @@index([recipientStaffId, createdAt])
  @@index([type])
  @@map("notifications")
}

/// Web Push 구독 정보 — 직원당 N개 (브라우저/디바이스별).
/// endpoint 가 unique 키. 410 Gone 응답 시 자동 삭제 대상.
model StaffPushSubscription {
  id        String   @id @default(cuid())
