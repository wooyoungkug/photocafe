# Database
DATABASE_URL="postgresql://user:PASSWORD@localhost:5432/printing_erp"

# JWT (최소 32자 랜덤 문자열 필수)
# 생성 예: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="최소32자_랜덤문자열_여기에_입력"
JWT_EXPIRES_IN="1h"
JWT_REFRESH_EXPIRES_IN="7d"

# 개인정보(PII) 컬럼 암호화 키 (AES-256-GCM, 설계서 v1.1)
# 생성 예: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ⚠️ 키를 분실하면 기존 암호화된 데이터를 복호화할 수 없습니다.
#    운영환경에서는 Railway/Vercel Secret Manager 또는 별도 KMS 사용 권장.
PII_ENCRYPTION_KEY=""
PII_KEY_VERSION="v1"
# 검색용 결정적 해시(이메일 unique 등)에 추가되는 페퍼. 키와 별도 보관.
PII_HASH_PEPPER=""

# App
API_PORT=3001
FRONTEND_URL="http://localhost:3002"
NODE_ENV="development"

# CORS (운영환경 추가 origin, 콤마 구분)
CORS_ORIGINS=""

# Naver OAuth
NAVER_CLIENT_ID="네이버개발자센터에서_발급"
NAVER_CLIENT_SECRET="네이버개발자센터에서_재발급"
NAVER_CALLBACK_URL="http://localhost:3001/api/v1/auth/naver/callback"

# Kakao OAuth
KAKAO_CLIENT_ID=""
KAKAO_CLIENT_SECRET=""
KAKAO_CALLBACK_URL="http://localhost:3001/api/v1/auth/kakao/callback"

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:3001/api/v1/auth/staff/google/callback"
GOOGLE_CUSTOMER_CALLBACK_URL="http://localhost:3001/api/v1/auth/google/callback"

# 직원 소셜 로그인 콜백
STAFF_NAVER_CALLBACK_URL="http://localhost:3001/api/v1/auth/staff/naver/callback"
STAFF_KAKAO_CALLBACK_URL="http://localhost:3001/api/v1/auth/staff/kakao/callback"

# SMTP (이메일 발송)
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS="이메일서비스_앱비밀번호_입력"
SMTP_FROM_NAME="Printing114"

# Solapi (SMS + 카카오 알림톡 통합)
# https://console.solapi.com 가입 → API Key 관리에서 발급
SOLAPI_API_KEY=""
SOLAPI_API_SECRET=""
SOLAPI_SENDER_NO=""                    # 발신번호 (사전 등록 필요)
SOLAPI_PF_ID=""                        # 카카오채널 ID (알림톡 사용 시 필요, SMS만 사용 시 비워두기)

# Web Push VAPID (npx web-push generate-vapid-keys 로 생성)
# 미설정 시 Web Push 발송이 비활성화됩니다 (인앱/카카오는 정상 동작).
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:admin@photocafe.co.kr"

# Seed 관리자 기본 비밀번호 (미설정시 랜덤 생성)
ADMIN_DEFAULT_PASSWORD=""

# AWS S3 (Optional)
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="ap-northeast-2"
AWS_S3_BUCKET=""

# 스마트택배 배송 추적 API (https://www.sweettracker.co.kr)
# 무료 플랜: 500건/일, 가입 후 즉시 발급
SWEETTRACKER_API_KEY=""

# 로젠택배 B2B API (https://openapihome.ilogen.com)
# 로젠택배 영업담당자에게 B2B API 연동 요청 후 발급
LOGEN_USER_ID=""         # 업체코드 (8자리)
LOGEN_CUST_CD=""         # 거래처코드 (8자리)
LOGEN_API_KEY=""         # API 인증 키 (Bearer token)
LOGEN_API_ENV="dev"      # dev | prod

# (구) NHN Cloud 설정 - Solapi로 대체됨, 아래 설정은 사용되지 않음
# KAKAO_ALIMTALK_APP_KEY=""
# KAKAO_ALIMTALK_SECRET_KEY=""
# KAKAO_ALIMTALK_SENDER_KEY=""
# KAKAO_ALIMTALK_ENABLED="false"

# 공공데이터포털 API (https://www.data.go.kr)
# 한국천문연구원 특일 정보 → 공휴일 자동 연동
# 가입 후 "한국천문연구원_특일 정보" 활용신청 → 디코딩 키 입력
DATA_GO_KR_API_KEY=""

# File Upload
# 업로드 base 경로 (임시 temp 파일 / 주문 orders / 상품 products 등의 루트)
# 로컬: 절대경로 권장 (예: C:/dev/printing114/apps/api/uploads)
# 운영(Docker): 컨테이너 내부 절대경로 (예: /app/uploads)
UPLOAD_BASE_PATH="./uploads"
UPLOAD_MAX_FILE_SIZE=52428800
THUMBNAIL_MAX_SIZE=500

# Backblaze B2 (S3 API) — 2버킷: private=원본·완성본, public=썸네일·로고 (docs/INFRASTRUCTURE.md)
# B2 콘솔: Application Key에 두 버킷 권한 부여, endpoint는 S3-Compatible 의 값 사용
# 미설정 시 API는 로컬 UPLOAD_BASE_PATH만 사용 (B2StorageService.isEnabled() === false)
B2_S3_ENDPOINT="https://s3.us-east-005.backblazeb2.com"
B2_KEY_ID=""
B2_APPLICATION_KEY=""
# Private: 프리사인드 URL(기본 300초)로만 접근 권장
B2_PRIVATE_BUCKET="photocafe-private"
# Public: 캐시-friendly URL — 미설정이면 public 업로드/URL API 미사용
B2_PUBLIC_BUCKET="photocafe-public"
# 생략 시 https://f005.backblazeb2.com/file/{B2_PUBLIC_BUCKET} … Cloudflare 붙이면 풀 URL로 지정
# B2_PUBLIC_BASE_URL="https://cdn.photocafe.co.kr/file/photocafe-public"
# GET 프리사인 만료(초), 기본 300
# B2_PRESIGN_EXPIRES_IN=300
# 하위호환(기존 이름) — B2_S3_* 가 있으면 이쪽은 안 써도 됨
# B2_ORIGINALS_ENDPOINT= B2_ORIGINALS_KEY_ID= B2_ORIGINALS_APP_KEY= B2_ORIGINALS_BUCKET=
