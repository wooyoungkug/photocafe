# Database
DATABASE_URL="postgresql://user:PASSWORD@localhost:5432/printing_erp"

# JWT (최소 32자 랜덤 문자열 필수)
JWT_SECRET="최소32자_랜덤문자열_여기에_입력"
JWT_EXPIRES_IN="1h"
JWT_REFRESH_EXPIRES_IN="7d"

# App
API_PORT=3001
FRONTEND_URL="http://localhost:3002"
NODE_ENV="development"

# CORS (운영환경 추가 origin, 콤마 구분)
CORS_ORIGINS=""

# Naver OAuth
NAVER_CLIENT_ID="네이버개발자센터에서_발급"
NAVER_CLIENT_SECRET="네이버개발자센터에서_재발급"
NAVER_CALLBACK_URL="http://localhost:3001/api/v1/auth/naver/callback"

# Kakao OAuth
KAKAO_CLIENT_ID=""
KAKAO_CLIENT_SECRET=""
KAKAO_CALLBACK_URL="http://localhost:3001/api/v1/auth/kakao/callback"

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:3001/api/v1/auth/staff/google/callback"
GOOGLE_CUSTOMER_CALLBACK_URL="http://localhost:3001/api/v1/auth/google/callback"

# 직원 소셜 로그인 콜백
STAFF_NAVER_CALLBACK_URL="http://localhost:3001/api/v1/auth/staff/naver/callback"
STAFF_KAKAO_CALLBACK_URL="http://localhost:3001/api/v1/auth/staff/kakao/callback"

# SMTP (이메일 발송)
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS="이메일서비스_앱비밀번호_입력"
SMTP_FROM_NAME="Printing114"

# NHN Cloud SMS (전화번호 인증)
NHN_SMS_APP_KEY=""
NHN_SMS_SECRET_KEY=""
NHN_SMS_SENDER_NO=""

# Seed 관리자 기본 비밀번호 (미설정시 랜덤 생성)
ADMIN_DEFAULT_PASSWORD=""

# AWS S3 (Optional)
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="ap-northeast-2"
AWS_S3_BUCKET=""

# 스마트택배 배송 추적 API (https://www.sweettracker.co.kr)
# 무료 플랜: 500건/일, 가입 후 즉시 발급
SWEETTRACKER_API_KEY=""

# 로젠택배 B2B API (https://openapihome.ilogen.com)
# 로젠택배 영업담당자에게 B2B API 연동 요청 후 발급
LOGEN_USER_ID=""         # 업체코드 (8자리)
LOGEN_CUST_CD=""         # 거래처코드 (8자리)
LOGEN_API_KEY=""         # API 인증 키 (Bearer token)
LOGEN_API_ENV="dev"      # dev | prod

# 카카오 알림톡 - NHN Cloud KakaoTalk Bizmessage
# 1) NHN Cloud 콘솔 → KakaoTalk Bizmessage 서비스 활성화
# 2) 발신 프로필(카카오톡 채널) 등록 → senderKey 발급
# 3) 알림톡 템플릿 등록 & 승인
KAKAO_ALIMTALK_APP_KEY=""          # NHN Cloud Bizmessage AppKey
KAKAO_ALIMTALK_SECRET_KEY=""       # NHN Cloud Bizmessage SecretKey
KAKAO_ALIMTALK_SENDER_KEY=""       # 카카오톡 채널 발신프로필 키
KAKAO_ALIMTALK_ENABLED="false"     # true로 변경하면 알림톡 발송 활성화

# 공공데이터포털 API (https://www.data.go.kr)
# 한국천문연구원 특일 정보 → 공휴일 자동 연동
# 가입 후 "한국천문연구원_특일 정보" 활용신청 → 디코딩 키 입력
DATA_GO_KR_API_KEY=""
