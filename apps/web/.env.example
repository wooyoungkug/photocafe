# 백엔드 API 베이스 URL (브라우저/서버 공용)
# 운영(Vercel): https://api.photocafe.co.kr/api/v1
# 로컬: http://localhost:3001/api/v1
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# 이미지 CDN 베이스 URL (Backblaze B2 + Cloudflare)
# 운영(Vercel): https://cdn.photocafe.co.kr
# 로컬: 미설정 (NEXT_PUBLIC_API_URL 의 /uploads 프록시 사용)
NEXT_PUBLIC_CDN_URL=

# 사이트 정식 URL (메타태그/OG/canonical 용)
# 운영(Vercel): https://photocafe.co.kr
NEXT_PUBLIC_SITE_URL=http://localhost:3002

# 기본 로케일 (ko / en / ja / zh)
NEXT_PUBLIC_DEFAULT_LOCALE=ko

# TinyMCE 에디터 API 키 (자체 키 발급)
NEXT_PUBLIC_TINYMCE_API_KEY=

# 개발 환경 자동 로그인용 (로컬에서만 사용, 운영 배포 시 비워둘 것)
NEXT_PUBLIC_DEV_ADMIN_ID=
NEXT_PUBLIC_DEV_ADMIN_PASSWORD=

# Web Push (VAPID 공개키)
# 백엔드 web-push 모듈에서 생성한 publicKey 를 입력합니다.
# 공개키이므로 클라이언트 노출은 안전합니다 (개인키는 백엔드 .env 에만 보관).
# 비어 있으면 Push 구독 로직이 조용히 skip 됩니다.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
