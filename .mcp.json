{
  "mcpServers": {
    "fetch": {
      "command": "uvx",
      "args": [
        "mcp-server-fetch"
      ]
    },
    "kakao-navigation": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@smithery/cli@3.19.0",
        "run",
        "@CaChiJ/kakao-navigation-mcp-server",
        "--config",
        "{\"kakaoRestApiKey\":\"3cf0eb4033e4fcb5a991b5cdfbfacbcd\"}"
      ],
      "env": {
        "KAKAO_REST_API_KEY": "3cf0eb4033e4fcb5a991b5cdfbfacbcd"
      }
    },
    "playwright": {
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest"
      ]
    },
    "sequential-thinking": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ]
    },
    "memory": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-memory"
      ]
    },
    "context7": {
      "command": "npx",
      "args": [
        "@upstash/context7-mcp"
      ]
    },
    "vercel": {
      "url": "https://mcp.vercel.com",
      "type": "http"
    },
    "postgres": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-postgres",
        "postgresql://postgres:postgres@localhost:5432/printing_erp"
      ]
    },
    "github": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ]
    },
    "brave-search": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-brave-search"
      ]
    },
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "C:/dev/photocafe",
        "C:/dev/printing114",
        "C:/tmp"
      ]
    },
    "puppeteer": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-puppeteer"
      ]
    },
    "cloudflare-dns": {
      "command": "npx",
      "args": ["mcp-remote", "https://dns-analytics.mcp.cloudflare.com/mcp"]
    }
  }
}
