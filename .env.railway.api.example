# ================================================================
# Railway - API Service Environment Variables Template
# ================================================================
# 사용법:
#   1. 이 파일을 .env.railway.api 로 복사 (gitignored)
#   2. 실제 시크릿 값을 채움 (이 파일 자체는 절대 커밋하지 말 것)
#   3. Railway 대시보드 → api 서비스 → Variables → Raw Editor 에 붙여넣기
#      또는 Railway CLI 로 일괄 등록:
#        railway variables set --service api $(cat .env.railway.api | grep -v '^#' | xargs)
#
# 참고:
#   - ${{Postgres.DATABASE_URL}} 같은 표기는 Railway 변수 참조 문법입니다.
#     Railway 대시보드의 Raw Editor 에 그대로 입력하면 자동으로 다른 서비스 변수를 참조합니다.
#   - CLI 로 등록할 때는 따옴표 처리가 필요합니다.
# ================================================================

# ----- Core -----
NODE_ENV=production
TZ=Asia/Seoul
PORT=3001

# Railway Postgres 플러그인이 자동 주입한 변수 참조
# (커넥션 풀 옵션이 필요하면 코드 측에서 조립하거나 Railway 변수에 직접 작성)
DATABASE_URL=${{Postgres.DATABASE_URL}}

# ----- JWT (32자 이상 랜덤 문자열, 운영 이전 시 재발급 필수) -----
JWT_SECRET=
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# ----- Frontend / CORS -----
# web 서비스의 Public Domain 자동 참조
FRONTEND_URL=https://${{web.RAILWAY_PUBLIC_DOMAIN}}
CORS_ORIGINS=https://${{web.RAILWAY_PUBLIC_DOMAIN}}

# ----- File Upload (Volume 마운트 필수) -----
# Railway 대시보드: api → Volumes → Mount Path: /app/uploads
UPLOAD_BASE_PATH=/app/uploads
UPLOAD_MAX_FILE_SIZE=52428800
THUMBNAIL_MAX_SIZE=500

# ----- Memory (PDF 생성 등 메모리 집약 작업용) -----
NODE_OPTIONS=--max-old-space-size=1536

# ================================================================
# OAuth - 각 콘솔에서 Railway 도메인을 콜백 URL 로 등록 필수
# ================================================================

# ----- Naver OAuth -----
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_CALLBACK_URL=https://${{api.RAILWAY_PUBLIC_DOMAIN}}/api/v1/auth/naver/callback
STAFF_NAVER_CALLBACK_URL=https://${{api.RAILWAY_PUBLIC_DOMAIN}}/api/v1/auth/staff/naver/callback

# ----- Kakao OAuth -----
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_CALLBACK_URL=https://${{api.RAILWAY_PUBLIC_DOMAIN}}/api/v1/auth/kakao/callback
STAFF_KAKAO_CALLBACK_URL=https://${{api.RAILWAY_PUBLIC_DOMAIN}}/api/v1/auth/staff/kakao/callback
KAKAO_REST_API_KEY=

# ----- Google OAuth -----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://${{api.RAILWAY_PUBLIC_DOMAIN}}/api/v1/auth/staff/google/callback
GOOGLE_CUSTOMER_CALLBACK_URL=https://${{api.RAILWAY_PUBLIC_DOMAIN}}/api/v1/auth/google/callback

# ================================================================
# 이메일 / SMS
# ================================================================

# ----- SMTP -----
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=Printing114

# ----- Solapi (SMS + 카카오 알림톡) -----
SOLAPI_API_KEY=
SOLAPI_API_SECRET=
SOLAPI_SENDER_NO=
SOLAPI_PF_ID=

# ================================================================
# 택배 연동
# ================================================================

# ----- 스마트택배 (배송추적) -----
SWEETTRACKER_API_KEY=

# ----- 로젠택배 B2B -----
LOGEN_USER_ID=
LOGEN_CUST_CD=
LOGEN_API_KEY=
LOGEN_API_ENV=prod

# ================================================================
# 기타
# ================================================================

# ----- 공공데이터포털 (공휴일 자동 연동) -----
DATA_GO_KR_API_KEY=

# ----- Seed 관리자 초기 비밀번호 (시드 후 즉시 변경할 것) -----
ADMIN_DEFAULT_PASSWORD=

# ----- AWS S3 (Optional) -----
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-northeast-2
AWS_S3_BUCKET=
