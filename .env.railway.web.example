# ================================================================
# Railway - Web Service Environment Variables Template
# ================================================================
# 사용법:
#   1. 이 파일을 .env.railway.web 으로 복사 (gitignored)
#   2. 실제 값을 채움
#   3. Railway 대시보드 → web 서비스 → Variables → Raw Editor 에 붙여넣기
#
# 중요:
#   - NEXT_PUBLIC_* 변수는 빌드 시점에 정적으로 인라인됩니다.
#     변경 후에는 반드시 web 서비스를 Redeploy 해야 반영됩니다.
#   - INTERNAL_API_URL 은 Railway Private Networking 을 사용하여
#     외부 트래픽 비용 없이 api 서비스와 통신합니다.
# ================================================================

# ----- Core -----
NODE_ENV=production
TZ=Asia/Seoul
PORT=3000
HOSTNAME=0.0.0.0

# ----- API 연결 -----
# Private Network: web 컨테이너에서만 접근 가능 (외부에서 보이지 않음)
INTERNAL_API_URL=http://api.railway.internal:3001

# Public: 클라이언트(브라우저)에서 호출하는 URL (빌드 시점에 인라인됨)
NEXT_PUBLIC_API_URL=https://${{api.RAILWAY_PUBLIC_DOMAIN}}
