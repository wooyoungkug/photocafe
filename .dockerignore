# ===========================================
# Docker Build Context 최적화
# 목표: 빌드에 필요한 소스코드만 포함 (~20MB)
# ===========================================

# Dependencies (all levels)
**/node_modules
**/.pnp
**/.pnp.js

# Build outputs
**/.next
**/dist
**/build
**/out
**/coverage
**/.nyc_output
**/.turbo
**/*.tsbuildinfo

# Git
.git
.gitignore
.gitattributes

# Environment
**/.env
**/.env.*
.env.production.example

# IDE & Editor
.vscode
.idea
**/*.swp
**/*.swo

# OS
.DS_Store
Thumbs.db
nul

# Logs
**/*.log
**/npm-debug.log*

# Claude Code (worktrees can be very large)
.claude

# Uploads (production data - can be GB+ on server)
**/uploads

# Documentation (not needed for build)
**/*.md
LICENSE

# Scripts & tools (not needed for build)
# 주의: 루트 컨텍스트로 빌드할 때만 적용됨.
# apps/api/.dockerignore 가 자체 컨텍스트(=apps/api/)를 별도 관리하므로
# 그 안의 scripts/ (entrypoint 포함) 는 영향받지 않는다.
/scripts
deploy.sh
tools
docs

# Docker & CI config (prevent recursive inclusion)
docker-compose*.yml
Dockerfile
.dockerignore
.github

# Windows/misc files
*.ps1
*.bat
*.sql
*.code-workspace
railway.json
.npmrc
